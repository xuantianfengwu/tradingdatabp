.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 30rpx;
}

.list-header {
  padding: 30rpx;
  background-color: #fafafa;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.source-list {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.source-card {
  background-color: white;
  border-radius: 16rpx;
  padding: 25rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.source-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.title-wrapper {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.source-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.link-btn {
  padding: 6rpx 15rpx;
  background-color: #1E88E5;
  color: white;
  border-radius: 15rpx;
  font-size: 20rpx;
  font-weight: 500;
  border: none;
}

.detail-btn {
  font-size: 22rpx;
  color: #1E88E5;
}

.source-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.source-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 15rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #f5f5f5;
}

.tag {
  padding: 8rpx 15rpx;
  background-color: #e3f2fd;
  color: #1E88E5;
  border-radius: 15rpx;
  font-size: 22rpx;
}

.wechat-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
  padding: 20rpx;
}

.wechat-item {
  background-color: white;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.wechat-name {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.wechat-desc {
  font-size: 22rpx;
  color: #666;
}

.research-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
  padding: 20rpx;
}

.research-item {
  background-color: white;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.research-name {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.research-desc {
  font-size: 22rpx;
  color: #666;
}