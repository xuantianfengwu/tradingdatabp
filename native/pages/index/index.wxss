.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 20rpx;
}

.header {
  background: linear-gradient(135deg, #1E88E5 0%, #1976D2 100%);
  padding: 60rpx 30rpx;
  text-align: center;
  color: white;
}

.logo {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

.content {
  padding: 20rpx;
}

.card {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.card-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.guide-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.guide-item {
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
}

.guide-number {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #1E88E5 0%, #1976D2 100%);
  color: white;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.guide-text {
  flex: 1;
  font-size: 25rpx;
  color: #666;
  line-height: 1.6;
  padding-top: 5rpx;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.feature-item {
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 25rpx;
  text-align: center;
  transition: all 0.3s ease;
}

.feature-item:hover {
  background-color: #e3f2fd;
  transform: translateY(-2rpx);
}

.feature-icon {
  font-size: 56rpx;
  display: block;
  margin-bottom: 15rpx;
}

.feature-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.feature-desc {
  display: block;
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
}

.market-overview {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.market-item {
  text-align: center;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.market-name {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.market-price {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.market-change {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
}

.up {
  color: #4CAF50;
}

.down {
  color: #F44336;
}

.strategy-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.strategy-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.strategy-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.strategy-return {
  font-size: 24rpx;
  color: #4CAF50;
  margin-right: 20rpx;
}

.strategy-sharpe {
  font-size: 24rpx;
  color: #1E88E5;
}

.footer {
  text-align: center;
  padding: 40rpx 20rpx;
  font-size: 22rpx;
  color: #999;
}
