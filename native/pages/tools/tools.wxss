.container {
  min-height: 100vh;
  background-color: #f5f7fa;
}

.header-section {
  background: linear-gradient(135deg, #1E88E5 0%, #1976D2 100%);
  padding: 40rpx 30rpx;
  text-align: center;
  color: white;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.header-subtitle {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
}

.category-scroll {
  background-color: white;
  white-space: nowrap;
  padding: 20rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.category-tabs {
  display: inline-flex;
  padding: 0 20rpx;
  gap: 15rpx;
}

.category-item {
  padding: 15rpx 30rpx;
  border-radius: 25rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #f0f0f0;
  transition: all 0.3s ease;
}

.category-item.active {
  background-color: #1E88E5;
  color: white;
}

.content-swiper {
  height: calc(100vh - 220rpx);
}

.tab-content {
  height: 100%;
}

.section-block {
  margin-top: 20rpx;
}

.block-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  margin-bottom: 15rpx;
}

.block-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.block-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.view-all-btn {
  font-size: 22rpx;
  color: #1E88E5;
}

.source-list {
  padding: 0 20rpx;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.source-card {
  background-color: white;
  border-radius: 16rpx;
  padding: 25rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.source-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.title-wrapper {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.source-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.link-btn {
  padding: 6rpx 15rpx;
  background-color: #1E88E5;
  color: white;
  border-radius: 15rpx;
  font-size: 20rpx;
  font-weight: 500;
  border: none;
}

.detail-btn {
  font-size: 22rpx;
  color: #1E88E5;
}

.source-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.source-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 15rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #f5f5f5;
}

.tag {
  padding: 8rpx 15rpx;
  background-color: #e3f2fd;
  color: #1E88E5;
  border-radius: 15rpx;
  font-size: 22rpx;
}
